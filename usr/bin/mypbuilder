#!/bin/sh
# Author: Aron Xu <user@example.com>
# License: GPL-3

BASEDIR="$HOME/pbuilder"
PBUILDER_TMP=/tmp/pbuilder

DIST=$1
DEB_TARGET_ARCH=$2
OPERATION=$3
DSCFILE=$4
DEPSDIR=$5

for i in dpkg-architecture pbuilder pigz debootstrap; do
    if ! PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin command -v "$i" > /dev/null 2>&1; then
        printf 'E: Required command "%s" not found.\n' "$i" 1>&2
        exit 1
    fi
done

DEBOOTSTRAP=debootstrap

if ! dpkg-architecture -a"$DEB_TARGET_ARCH" >/dev/null 2>&1; then
    printf "E: \"$DEB_TARGET_ARCH\" is not a valid architecture.\n" 1>&2
    exit 1
else
    DEB_HOST_ARCH=`dpkg-architecture -qDEB_HOST_ARCH`
    DEB_HOST_ARCH_BITS=`dpkg-architecture -qDEB_HOST_ARCH_BITS`
    DEB_TARGET_ARCH_BITS=`dpkg-architecture -a$DEB_TARGET_ARCH -qDEB_HOST_ARCH_BITS`
fi

unset ARG
if [ $DEB_HOST_ARCH_BITS -gt $DEB_TARGET_ARCH_BITS ]; then
    ARG="$ARG linux32";
elif [ $DEB_HOST_ARCH_BITS -lt $DEB_TARGET_ARCH_BITS ]; then
    printf "E: Can not build $DEB_TARGET_ARCH package on this machine.\n" 1>&2
    exit 1
fi

if echo "$DIST" | grep -q "bpo$"; then
	DISTRO=`echo $DIST | sed 's/bpo$//'`
else
    DISTRO=$DIST
fi

if ! [ -d $BASEDIR/etc ]; then
    printf "E: $BASEDIR/etc does not exist, BASEDIR not valid.\n" 1>&2
    exit 1
elif ! [ -s $BASEDIR/etc/$DIST-$DEB_TARGET_ARCH ]; then
    printf "E: $BASEDIR/etc/$DIST-$DEB_TARGET_ARCH pbuilderrc file does not exist or empty.\n" 1>&2
    exit 1
fi

if ! [ -d $BASEDIR/base ]; then
    printf "W: $BASEDIR/base does not exist, creating.\n" 1>&2
    mkdir -p $BASEDIR/base
fi

if [ -n "$DEPSDIR" ]; then
    if ! [ -d "$DEPSDIR" ]; then
        printf 'E: Deps directory "%s" does not exist.\n' "$DEPSDIR" 1>&2
        exit 1
    fi
    DEPSDIR=$(cd "$DEPSDIR" && pwd)
    if ! command -v apt-ftparchive > /dev/null 2>&1; then
        printf 'E: apt-ftparchive not found. Install apt-utils.\n' 1>&2
        exit 1
    fi
    (cd "$DEPSDIR" && apt-ftparchive packages . > Packages)
fi

if ! [ -d $BASEDIR/hooks ]; then
    printf "W: $BASEDIR/hooks does not exist, creating.\n" 1>&2
    mkdir -p $BASEDIR/hooks
fi

for i in logs result; do
    if ! [ -d $BASEDIR/$i/$DIST-$DEB_TARGET_ARCH ]; then
        printf "W: Directory $BASEDIR/$i/$DIST-$DEB_TARGET_ARCH does not exist, creating.\n" 1>&2
        mkdir -p $BASEDIR/$i/$DIST-$DEB_TARGET_ARCH
    fi
done

PBUILDER_ACTION=$OPERATION
if [ "$OPERATION" = "create" ]; then
    PROCEED=true
elif ! [ -s $BASEDIR/base/$DIST-$DEB_TARGET_ARCH-base.tgz ]; then
    printf "E: $BASEDIR/base/$DIST-$DEB_TARGET_ARCH-base.tgz does not exist or empty.\n" 1>&2
    exit 1
else
    case $OPERATION in
        build )
            if ! [ -s $DSCFILE ]; then
                printf "E: $DSCFILE does not exist or empty.\n" 1>&2
                exit 1
            else
                BASENAME=`basename $DSCFILE .dsc`
            fi
            PROCEED=true
            ;;
        autopkgtest )
            if ! [ -s $DSCFILE ]; then
                printf "E: $DSCFILE does not exist or empty.\n" 1>&2
                exit 1
            else
                BASENAME=`basename $DSCFILE .dsc`
            fi
            AUTOPKGTEST=true
            ;;
        update|clean|execute|debuild )
            PROCEED=true
            ;;
        login )
            LOGIN=true
            ;;
        edit )
            EDIT=true
            PBUILDER_ACTION=login
            ;;
        edit-script )
            EXEC=true
            PBUILDER_ACTION=execute
            ;;
        * )
            printf "E: Operations in build|create|update|login|execute|edit|edit-script|autopkgtest.\n" 1>&2
            exit 1
            ;;
    esac
fi

DATUM=`/bin/date +"%Y%m%d-%H%M"`
if ! [ -z $BASENAME ]; then
    LOG=$BASEDIR/logs/$DIST-$DEB_TARGET_ARCH/${OPERATION}_${BASENAME}_${DATUM}.log
else
    LOG=$BASEDIR/logs/$DIST-$DEB_TARGET_ARCH/${OPERATION}_${DATUM}.log
fi

# Consume the positional parameters already assigned above.
# dash treats `shift n` with n>$# as a fatal error, so check first.
if [ $# -ge 5 ]; then
    shift 5
else
    shift $#
fi
# If extra arguments are passed via --, strip the separator.
if [ "${1:-}" = "--" ]; then
    shift
fi

FUNC_PBUILDER_TMP() {
    if ! [ -d $PBUILDER_TMP ]; then
        printf "W: $PBUILDER_TMP does not exist, creating.\n" 1>&2
        sudo mkdir -p $PBUILDER_TMP
    fi
}

NJOBS=`nproc`
PBUILDER_CMD="sudo DEB_BUILD_PARALLEL=1 DEB_BUILD_OPTIONS=parallel=${NJOBS} $ARG pbuilder $PBUILDER_ACTION"
COMMON_ARGS="--override-config \
    --autocleanaptcache \
    --compressprog pigz \
    --debootstrap $DEBOOTSTRAP \
    --architecture $DEB_TARGET_ARCH \
    --distribution $DISTRO \
    --configfile $BASEDIR/etc/$DIST-$DEB_TARGET_ARCH \
    --hookdir $BASEDIR/hooks \
    --basetgz $BASEDIR/base/$DIST-$DEB_TARGET_ARCH-base.tgz"

if [ -n "$DEPSDIR" ]; then
    COMMON_ARGS="$COMMON_ARGS --bindmounts $DEPSDIR"
fi

run_pbuilder() {
    if [ -n "$DEPSDIR" ]; then
        $PBUILDER_CMD $COMMON_ARGS \
            --othermirror "deb [trusted=yes] file://$DEPSDIR ./" \
            "$@"
    else
        $PBUILDER_CMD $COMMON_ARGS "$@"
    fi
}

if [ "$AUTOPKGTEST" = "true" ]; then
    FUNC_PBUILDER_TMP
    for i in autopkgtest autopkgtest-virt-chroot; do
        if ! command -v "$i" > /dev/null 2>&1; then
            printf 'E: Required command "%s" not found. Install autopkgtest.\n' "$i" 1>&2
            exit 1
        fi
    done
    AUTOPKGTEST_CHROOT=$PBUILDER_TMP/autopkgtest-$$
    sudo mkdir -p "$AUTOPKGTEST_CHROOT"
    sudo tar -xzf $BASEDIR/base/$DIST-$DEB_TARGET_ARCH-base.tgz -C "$AUTOPKGTEST_CHROOT"
    AUTOPKGTEST_OUTDIR=$BASEDIR/logs/$DIST-$DEB_TARGET_ARCH/autopkgtest_${BASENAME}_${DATUM}
    rm -rf "$AUTOPKGTEST_OUTDIR"
    mkdir -p "$AUTOPKGTEST_OUTDIR"
    CHROOT_MOUNTS=""
    for mp in proc:proc:proc sysfs:sysfs:sys devtmpfs:udev:dev devpts:devpts:dev/pts; do
        FSTYPE=${mp%%:*}
        rest=${mp#*:}
        SRCNAME=${rest%%:*}
        RELPATH=${rest#*:}
        MOUNTPOINT="$AUTOPKGTEST_CHROOT/$RELPATH"
        sudo mkdir -p "$MOUNTPOINT"
        if sudo mount -t "$FSTYPE" "$SRCNAME" "$MOUNTPOINT"; then
            CHROOT_MOUNTS="$MOUNTPOINT $CHROOT_MOUNTS"
        else
            printf "W: Failed to mount %s on %s, continuing anyway.\n" "$FSTYPE" "$MOUNTPOINT" 1>&2
        fi
    done

    cleanup_chroot() {
        for mp in $CHROOT_MOUNTS; do
            sudo umount -l "$mp" 2>/dev/null || true
        done
        sudo rm -rf "$AUTOPKGTEST_CHROOT"
    }
    trap cleanup_chroot EXIT

    printf "I: Running autopkgtest on %s\n" "$DSCFILE"
    sudo autopkgtest "$DSCFILE" \
        -o "$AUTOPKGTEST_OUTDIR" \
        --build-parallel=${NJOBS} \
        -- chroot "$AUTOPKGTEST_CHROOT"
    AUTOPKGTEST_RC=$?
    cleanup_chroot
    trap - EXIT
    exit $AUTOPKGTEST_RC
elif [ "$PROCEED" = "true" ]; then
    FUNC_PBUILDER_TMP
    run_pbuilder \
        --buildresult $BASEDIR/result/$DIST-$DEB_TARGET_ARCH \
        --logfile $LOG \
        "$@" $DSCFILE
    [ -n "$DEPSDIR" ] && rm -f "$DEPSDIR/Packages"
elif [ "$LOGIN" = "true" ]; then
    FUNC_PBUILDER_TMP
    run_pbuilder
elif [ "$EDIT" = "true" ]; then
    FUNC_PBUILDER_TMP
    run_pbuilder --save-after-login
elif [ "$EXEC" = "true" ]; then
    FUNC_PBUILDER_TMP
    run_pbuilder \
        --logfile $LOG \
        --save-after-exec
fi
